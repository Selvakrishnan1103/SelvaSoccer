rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: is user authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: get user document of requester
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: is user an admin
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' ||
        // Fallback or seed admin email
        request.auth.token.email == 'selvakrish601@gmail.com'
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Teams collection
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches collection
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();

      // Nested subcollection for match events
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Tournaments collection
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
